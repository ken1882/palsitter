{
  "name": "palsitter-desktop",
  "version": "1.0.0",
  "description": "Palsitter desktop shell",
  "author": "Palsitter",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64"
  },
  "devDependencies": {
    "electron": "43.1.1",
    "electron-builder": "26.15.3"
  },
  "build": {
    "appId": "com.palsitter.desktop",
    "productName": "Palsitter",
    "asar": false,
    "directories": {
      "output": "dist",
      "buildResources": "build-resources"
    },
    "files": [
      "main.js",
      "package.json",
      "assets/**/*"
    ],
    "extraResources": [
      { "from": "source", "to": "backend" },
      { "from": "git-metadata", "to": "backend/.git" },
      { "from": "source/Pal/.gitkeep", "to": "backend/Pal/.gitkeep" },
      { "from": "source/artifacts/.gitkeep", "to": "backend/artifacts/.gitkeep" },
      { "from": "source/config/.gitkeep", "to": "backend/config/.gitkeep" },
      { "from": "source/logs/.gitkeep", "to": "backend/logs/.gitkeep" },
      { "from": "source/profile/.gitkeep", "to": "backend/profile/.gitkeep" },
      { "from": "runtime", "to": "python" },
      { "from": "git-runtime", "to": "git" }
    ],
    "win": {
      "icon": "build-resources/palsitter.ico",
      "target": [{ "target": "dir", "arch": ["x64"] }]
    }
  }
}
