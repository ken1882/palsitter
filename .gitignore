# Python
__pycache__/
*.py[cod]
.pytest_cache/
.coverage
htmlcov/

# Local environment
.venv/
venv/
env/

# Generated and runtime data
/artifacts/*
!/artifacts/.gitkeep
/config/*
!/config/.gitkeep
/logs/*
!/logs/.gitkeep
/Pal/*
!/Pal/.gitkeep
/profile/*
!/profile/.gitkeep
/tmp/*

# Electron build outputs
/desktop/node_modules/
/desktop/dist/
/desktop/runtime/
/desktop/git-runtime/
/desktop/git-metadata/
/desktop/source/
/desktop/.cache/
/desktop/.electron-gyp/
npm-debug.log*
*.tsbuildinfo
/desktop/assets/*.original

# OS/editor files
.DS_Store
Thumbs.db
*.swp
